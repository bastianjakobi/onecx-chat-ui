  "scripts": {
    "apigen": "openapi-generator-cli generate -i src/assets/swagger/onecx-chat-bff.yaml -c apigen.yaml -o src/app/shared/generated -g typescript-angular --type-mappings AnyType=object",
    "start": "nx serve --host 0.0.0.0 --disable-host-check",
